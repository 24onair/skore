# SKORE environment — copy to `.env` (git-ignored) and fill from your Supabase project.
# Supabase dashboard → Project Settings → API  (and → Database for the connection string).

# --- Backend (server-side secrets; also set these in Vercel → Environment Variables) ---
# Postgres connection string. Use the SUPABASE POOLER (Transaction mode, port 6543) for
# serverless — Dashboard → Database → Connection string → "Connection pooling" → URI.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role key — SECRET, backend only>
SUPABASE_JWT_SECRET=<Project Settings → API → JWT Settings → JWT Secret>

# --- Frontend (public; safe to expose in the browser) ---
SUPABASE_ANON_KEY=<anon public key>
