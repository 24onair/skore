{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb", "includeFiles": "{api,scoring}/**" }
    },
    { "src": "web/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/", "dest": "/web/landing.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/web/$1" }
  ]
}
